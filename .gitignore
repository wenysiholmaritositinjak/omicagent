# === 敏感配置 (绝不可提交) ===
.env
.env.*
!.env.example

# === Python 缓存与构建 ===
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
build/
dist/
.eggs/

# === 运行产物 (不入库, 本地生成) ===
logs/
results/
*.log

