*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
build/
dist/
.eggs/

# === 运行产物 (不入库, 本地生成) ===
logs/
results/
*.log

# === 数据与模型大文件 (不入库) ===
data/*
# 放行注释统一子项目的小型可复现产物 (zotero_index.json 含本地路径, 仍忽略)
!data/annotation/
data/annotation/*
!data/annotation/baseline.md
!data/annotation/scplantdb_ref.json
!data/annotation/corpus.csv
!data/annotation/p1_harvest_report.md
!data/annotation/mapping_table.v1.json
!data/annotation/p2_mapping_report.md
*.h5ad
*.h5
*.rds
*.Rds
*.mtx
*.mtx.gz
*.tsv.gz
*.csv.gz
*.gz
*.h5Seurat
*.pt
*.pth
*.pkl
*.npy
*.npz
# 但允许小的示例数据/测试 fixtures
!tests/data/*
!tests/fixtures/*

